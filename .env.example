# Supabase public project URL. Public: exposed to browser code.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key for browser and server Supabase clients. Public: exposed to browser code.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key for privileged server actions and API routes. Server-only secret.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe secret API key for server-side checkout and subscription operations. Server-only secret.
STRIPE_SECRET_KEY=

# Stripe webhook signing secret for /api/stripe/webhook. Server-only secret.
STRIPE_WEBHOOK_SECRET=

# Public marketing/site URL used for canonical URLs and social metadata. Public.
NEXT_PUBLIC_SITE_URL=

# Public app URL used for app links and Stripe checkout redirects. Public.
NEXT_PUBLIC_APP_URL=

# Server-only fallback app URL for Stripe checkout redirects when NEXT_PUBLIC_APP_URL is unset.
APP_URL=

# Vercel-provided production hostname fallback for checkout redirects. Server-only; usually unset locally.
VERCEL_PROJECT_PRODUCTION_URL=
